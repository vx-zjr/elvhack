---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { detectPreferredLang, getCategoryUrl, type PostLang } from "@/data/post";
import { siteConfig } from "@/site.config";

interface Props {
	lang?: PostLang | undefined;
}

const currentLang = Astro.props.lang ?? detectPreferredLang(Astro.url.pathname.split("/")[1]);
const otherLang = currentLang === "zh" ? "en" : "zh";
const pathname = Astro.url.pathname;
const technologyUrl = getCategoryUrl(currentLang, "technology");
const quantUrl = getCategoryUrl(currentLang, "quant");
const links = [
	{ active: pathname === "/", path: "/", title: "home" },
	{ active: pathname.startsWith(technologyUrl), path: technologyUrl, title: "TECHNOLOGY" },
	{ active: pathname.startsWith(quantUrl), path: quantUrl, title: "QUANT" },
	{ active: pathname.startsWith("/projects/"), path: "/projects/", title: "projects" },
	{ active: pathname.startsWith("/links/"), path: "/links/", title: "links" },
	{ active: false, path: getCategoryUrl(otherLang, "technology"), title: otherLang },
];
---

<header class="site-header">
	<div class="site-header__inner site-shell-wide">
		<a
			aria-current={pathname === "/" ? "page" : false}
			class="site-header__brand"
			href="/"
		>
			<b class="font-medium not-italic text-accent">elv</b>{siteConfig.title.replace("elv", "")}
		</a>
		<div class="site-header__right">
			<nav aria-label="Main menu" class="site-header__nav">
				{
					links.map((link) => (
						<a
							aria-current={link.active ? "page" : false}
							class="site-header__link"
							href={link.path}
						>
							{link.title}
						</a>
					))
				}
			</nav>
			<ThemeToggle />
		</div>
	</div>
</header>
