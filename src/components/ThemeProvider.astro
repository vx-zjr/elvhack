{/* Inlined to avoid FOUC. This is a parser blocking script. */}
<script is:inline>
	const darkModePref = window.matchMedia("(prefers-color-scheme: dark)");
	const themeStorageKey = "theme";
	const userChoiceStorageKey = "theme-user-choice";

	function getUserPref() {
		const storedTheme = typeof localStorage !== "undefined" && localStorage.getItem(themeStorageKey);
		return storedTheme || (darkModePref.matches ? "dark" : "light");
	}

	function setTheme(newTheme, persist) {
		if (newTheme !== "light" && newTheme !== "dark") {
			return console.warn(
				`Invalid theme value '${newTheme}' received. Expected 'light' or 'dark'.`,
			);
		}

		const root = document.documentElement;

		// root already set to newTheme, exit early
		if (newTheme === root.getAttribute("data-theme")) {
			return;
		}

		root.setAttribute("data-theme", newTheme);

		if (persist && typeof localStorage !== "undefined") {
			localStorage.setItem(themeStorageKey, newTheme);
			localStorage.setItem(userChoiceStorageKey, "true");
		}
	}

	// initial setup
	setTheme(getUserPref(), false);

	// View Transitions hook to restore theme
	document.addEventListener("astro:after-swap", () => setTheme(getUserPref(), false));

	// listen for theme-change custom event, fired in src/components/ThemeToggle.astro
	document.addEventListener("theme-change", (e) => {
		setTheme(e.detail.theme, true);
	});

	// listen for prefers-color-scheme changes until the user explicitly chooses.
	darkModePref.addEventListener("change", (e) => {
		const hasUserChoice =
			typeof localStorage !== "undefined" && localStorage.getItem(userChoiceStorageKey) === "true";
		if (!hasUserChoice) setTheme(e.matches ? "dark" : "light", false);
	});
</script>
