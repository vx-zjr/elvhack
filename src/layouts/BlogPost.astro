---
import { type CollectionEntry, render } from "astro:content";

import ArticleMeta from "@/components/blog/ArticleMeta.astro";
import ArticleToc from "@/components/blog/ArticleToc.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import PageShell from "@/components/layout/PageShell.astro";
import {
	findTranslation,
	getAllPosts,
	getAlternateLang,
	getCategoryUrl,
	getPostLikeSlug,
	getPostUrl,
	languageMeta,
} from "@/data/post";

import BaseLayout from "./Base.astro";

interface Props {
	noindex?: boolean;
	post: CollectionEntry<"post">;
}

const { noindex = false, post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate, tags } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = publishDate.toISOString();
const articleUpdatedDate = updatedDate?.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
const allPosts = await getAllPosts();
const targetLang = getAlternateLang(post.data.lang);
const translation = findTranslation(post, allPosts, targetLang);
const translationHref = translation
	? getPostUrl(translation)
	: getCategoryUrl(targetLang, post.data.category);
const translationLabel = post.data.lang === "zh" ? "English" : "中文";
const translationFallback = post.data.lang === "zh" ? "English version pending" : "中文版暂缺";
const alternateLinks = [
	{ href: getPostUrl(post), hreflang: languageMeta[post.data.lang].htmlLang },
	...(translation
		? [{ href: getPostUrl(translation), hreflang: languageMeta[translation.data.lang].htmlLang }]
		: []),
];
const likeSlug = getPostLikeSlug(post);
---

<BaseLayout
	bodyClass="article-page"
	meta={{
		alternateLinks,
		articleDate,
		articleTags: tags,
		articleUpdatedDate,
		canonical: getPostUrl(post),
		description,
		lang: post.data.lang,
		noindex,
		ogImage: socialImage,
		rssHref: `/${post.data.lang}/rss.xml`,
		title,
	}}
>
	<PageShell variant="wide">
		<article class="article-layout article-content" data-pagefind-body>
			<aside class="article-meta" aria-label="Article metadata">
				<ArticleMeta likeSlug={likeSlug} post={post} readingTime={readingTime} showLike />
			</aside>

			<div class="article-main">
				<header class="article-header" id="blog-hero">
					<p class="page-kicker">{post.data.category}</p>
					<h1 class="article-title">{title}</h1>
					{description && <p class="article-description">{description}</p>}
					<div class="article-mobile-meta">
						<ArticleMeta compact likeSlug={likeSlug} post={post} readingTime={readingTime} showLike />
					</div>
					<div class="mt-5 border-t border-faint pt-4 text-xs text-muted">
						{
							translation ? (
								<a class="cactus-link" href={translationHref}>
									{translationLabel}
								</a>
							) : (
								<>
									<span>{translationFallback}</span>
									<span aria-hidden="true"> / </span>
									<a class="cactus-link" href={translationHref}>
										{translationLabel}
									</a>
								</>
							)
						}
					</div>
				</header>

				<div class="prose">
					<slot />
					<WebMentions />
				</div>
			</div>

			{
				headings.length > 0 && (
					<aside class="article-toc" aria-label="Article table of contents">
						<ArticleToc headings={headings} />
					</aside>
				)
			}
		</article>
	</PageShell>

	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-surface text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>
