---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import { languageMeta } from "@/data/post";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: {
		alternateLinks,
		articleDate,
		canonical,
		description = siteConfig.description,
		lang,
		noindex,
		ogImage,
		ogLocale,
		rssHref,
		title,
	},
} = Astro.props;
const htmlLang = lang ? languageMeta[lang].htmlLang : siteConfig.lang;
---

<html class="scroll-smooth" data-theme="dark" lang={htmlLang}>
	<head>
		<BaseHead
			alternateLinks={alternateLinks}
			articleDate={articleDate}
			canonical={canonical}
			description={description}
			lang={lang}
			noindex={noindex}
			ogImage={ogImage}
			ogLocale={ogLocale}
			rssHref={rssHref}
			title={title}
		/>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-10 font-mono text-sm font-normal antialiased sm:px-8 sm:pt-14"
	>
		<SkipLink />
		<Header lang={lang} />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "immediate"
					}
				],
				"prerender": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "moderate"
					}
				]
			}
		</script>
	</body>
</html>
