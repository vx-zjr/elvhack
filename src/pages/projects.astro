---
import PageShell from "@/components/layout/PageShell.astro";
import SurfaceCard from "@/components/layout/SurfaceCard.astro";
import BaseLayout from "@/layouts/Base.astro";

const projects = [
	{
		name: "Personal Research System",
		description:
			"A long-running writing and retrieval workflow for research notes and technical posts.",
		status: "active",
		tags: ["Astro", "Knowledge Base", "Workflow"],
	},
	{
		name: "AI + Quant Notes",
		description:
			"Experiments and references around market data, strategy research, and AI tooling.",
		status: "idea",
		tags: ["AI", "Quant", "Research"],
	},
	{
		name: "OSINT Workflow Index",
		description:
			"A structured place for process notes, checklists, and source evaluation patterns.",
		status: "idea",
		tags: ["OSINT", "Security", "Systems"],
	},
];

const meta = {
	description: "elvhack research projects and engineering experiments.",
	title: "Projects",
};
---

<BaseLayout meta={meta}>
	<PageShell variant="wide">
		<header class="page-header">
			<p class="page-kicker">Projects</p>
			<h1 class="page-title">Research projects and engineering experiments.</h1>
			<p class="page-description">
				A quiet index for active systems, planned experiments, and durable technical artifacts.
			</p>
		</header>

		<div class="card-grid">
			{
				projects.map((project) => (
					<SurfaceCard>
						<div class="flex items-start justify-between gap-3">
							<h2 class="article-list-title">{project.name}</h2>
							<span class="tag-pill">{project.status}</span>
						</div>
						<p class="mt-3 text-sm leading-6 text-muted">{project.description}</p>
						<div class="tag-list mt-4">
							{project.tags.map((tag) => (
								<span class="tag-pill">{tag}</span>
							))}
						</div>
					</SurfaceCard>
				))
			}
		</div>
	</PageShell>
</BaseLayout>
