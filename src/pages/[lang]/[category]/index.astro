---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import ArticleListItem from "@/components/blog/ArticleListItem.astro";
import PostLikeCounts from "@/components/blog/PostLikeCounts.astro";
import PostSortControls from "@/components/blog/PostSortControls.astro";
import PageShell from "@/components/layout/PageShell.astro";
import {
	categoryMeta,
	getCategoryUrl,
	getPostsByCategory,
	getUniqueTagsWithCount,
	languageMeta,
	POST_CATEGORIES,
	POST_LANGS,
	type PostCategory,
	type PostLang,
} from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

export const getStaticPaths = (() => {
	return POST_LANGS.flatMap((lang) =>
		POST_CATEGORIES.map((category) => ({
			params: { category, lang },
			props: { category, lang },
		})),
	);
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { category, lang } = Astro.props as Props;
const currentLang = lang as PostLang;
const currentCategory = category as PostCategory;
const posts = await getPostsByCategory(currentLang, currentCategory);
const title = categoryMeta[currentCategory].label;
const description = categoryMeta[currentCategory].description[currentLang];
const tags = getUniqueTagsWithCount(posts).slice(0, 12);
---

<PageLayout
	meta={{
		alternateLinks: [
			{
				href: getCategoryUrl("zh", currentCategory),
				hreflang: languageMeta.zh.htmlLang,
			},
			{
				href: getCategoryUrl("en", currentCategory),
				hreflang: languageMeta.en.htmlLang,
			},
		],
		canonical: getCategoryUrl(currentLang, currentCategory),
		description,
		lang: currentLang,
		rssHref: `/${currentLang}/rss.xml`,
		title,
	}}
>
	<PageShell class="blog-index-page" variant="wide">
		<header class="page-header">
			<p class="page-kicker">Blog Index</p>
			<h1 class="page-title">{title}</h1>
			<p class="page-description">{description}</p>
		</header>

		<div class="blog-index-layout">
			<section class="post-list" aria-label={`${title} posts`}>
				{
					posts.length > 0 ? (
						<div class="compact-list" data-sortable-post-list>
							{posts.map((post) => (
								<ArticleListItem post={post} />
							))}
						</div>
					) : (
						<p class="text-muted">No posts yet.</p>
					)
				}
				<PostLikeCounts />
			</section>

			<aside class="blog-sidebar" aria-label="Blog controls">
				<section class="surface-card sidebar-block">
					<h2 class="sidebar-title">Sort</h2>
					<PostSortControls
						latestLabel={currentLang === "zh" ? "最新发布" : "Latest"}
						likesLabel={currentLang === "zh" ? "点赞最多" : "Likes"}
					/>
				</section>
				<section class="surface-card sidebar-block">
					<h2 class="sidebar-title">Index</h2>
					<p class="text-sm text-muted">{posts.length} posts</p>
				</section>
				{
					tags.length > 0 && (
						<section class="surface-card sidebar-block">
							<h2 class="sidebar-title">Tags</h2>
							<div class="tag-list">
								{tags.map(([tag, count]) => (
									<a class="tag-pill" href={`/${currentLang}/tags/${tag}/`}>
										#{tag} {count}
									</a>
								))}
							</div>
						</section>
					)
				}
			</aside>
		</div>
	</PageShell>
</PageLayout>
